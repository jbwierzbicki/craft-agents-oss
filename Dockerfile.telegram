FROM ghcr.io/lukilabs/craft-agents-server:latest

USER root
ENV HOME=/home/craftagents

RUN apt-get update && \
    apt-get install -y python3 python3-requests python3-websocket && \
    apt-get clean

COPY telegram-bridge.py /app/telegram-bridge.py

ENTRYPOINT []
CMD ["python3", "/app/telegram-bridge.py"]
